# =============================================================================
# QuoreB2B CRM - Backend Environment
# Domain: api.quoreb2b.com
# =============================================================================

NODE_ENV=development
PORT=4000
API_PREFIX=api
API_VERSION=v1

# Application
APP_NAME=QuoreB2B CRM API
APP_URL=https://api.quoreb2b.com

# CORS
CORS_ORIGINS=https://crm.quoreb2b.com,https://app.intentmatics.com,http://localhost:3000,http://localhost:3001

# MongoDB
MONGODB_URI=mongodb://quoreb2b:quoreb2b_secret@localhost:27017/quoreb2b_crm?authSource=admin
MONGODB_MAX_POOL_SIZE=10

# Redis (false = skip BullMQ when Redis/Docker unavailable)
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_PREFIX=quoreb2b

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=quoreb2b-crm-uploads
AWS_S3_ENDPOINT=

# AWS SES
AWS_SES_FROM_EMAIL=noreply@quoreb2b.com
AWS_SES_FROM_NAME=QuoreB2B CRM

# BullMQ
BULLMQ_PREFIX=quoreb2b

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Logging
LOG_LEVEL=debug

# Socket.io
SOCKET_CORS_ORIGINS=https://crm.quoreb2b.com,https://app.intentmatics.com,http://localhost:3000,http://localhost:3001
