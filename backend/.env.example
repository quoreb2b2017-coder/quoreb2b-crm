# =============================================================================
# QuoreB2B CRM - Backend Environment
# Domain: api.quoreb2b.com
# =============================================================================

NODE_ENV=development
PORT=4000
API_PREFIX=api
API_VERSION=v1

# Application
APP_NAME=QuoreB2B CRM API
APP_URL=https://api.quoreb2b.com

# CORS
CORS_ORIGINS=https://crm.quoreb2b.com,https://app.intentmatics.com,http://localhost:3000,http://localhost:3001

# MongoDB
MONGODB_URI=mongodb://quoreb2b:quoreb2b_secret@localhost:27017/quoreb2b_crm?authSource=admin
MONGODB_MAX_POOL_SIZE=30
# Sync schema indexes on startup (recommended for Atlas / 10M+ rows)
MONGODB_SYNC_INDEXES=true

# Redis — BullMQ queues + shared cache (MX DNS, dashboard)
# Must be Redis 5+ when REDIS_ENABLED=true (Memurai on Windows, Docker redis on Linux)
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_PREFIX=quoreb2b:cache
REDIS_CACHE_TTL_LIVE_SECONDS=15
REDIS_CACHE_TTL_SECONDS=60
REDIS_CACHE_TTL_MEDIUM_SECONDS=180
REDIS_CACHE_TTL_LONG_SECONDS=600

# Elasticsearch — optional; Leads fast search only (not bulk email / batches)
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_PREFIX=quoreb2b

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# BullMQ
BULLMQ_PREFIX=quoreb2b

# Bulk Email Verification — in-house engine (DNS + MX; no third-party API)
BULK_EMAIL_VERIFICATION_PROVIDER=internal
# false = run mailbox RCPT check (recommended; aligns invalid with verifier UIs)
# true = MX/DNS only — more "valid", misses mailbox failures
BULK_EMAIL_SKIP_SMTP_PROBE=false
BULK_EMAIL_SMTP_FROM=verify@quoreb2b.com
# Lower = faster (fail quicker on slow MX). 5000 recommended locally.
BULK_EMAIL_SMTP_TIMEOUT_MS=5000
# false = try all patterns per person, then pick best (recommended vs ZeroBounce)
BULK_EMAIL_STOP_ON_VALID=false
# Parallel prospects per chunk (8 = faster; lower if DNS timeouts)
BULK_EMAIL_PROSPECT_CONCURRENCY=8
# Parallel email patterns per prospect (same logic, ~6x faster SMTP phase)
BULK_EMAIL_PATTERN_CONCURRENCY=6
BULK_EMAIL_QUEUE_CONCURRENCY=8
# All email patterns per person (12 = full pattern list)
BULK_EMAIL_MAX_PATTERNS=12
# Skip slow SMTP catch-all probe (improves accuracy + speed)
BULK_EMAIL_SKIP_CATCH_ALL_PROBE=true
BULK_EMAIL_MX_ONLY_FALLBACK=true
# false = trust MX when SMTP probe fails (fewer false invalids, ZeroBounce-like)
# true = only explicit 5.1.x / "user unknown" on SMTP marks invalid
BULK_EMAIL_STRICT_MAILBOX_REJECT=false
BULK_EMAIL_DOMAIN_CACHE_TTL_MS=3600000
# Failed MX/DNS lookups retry after 5 min (not 1 hour — avoids false "MX failed")
BULK_EMAIL_DNS_NEGATIVE_CACHE_TTL_MS=300000
BULK_EMAIL_MAX_ROWS_PER_BATCH=100000
# Optional: path to extra disposable-domains JSON array
# BULK_EMAIL_DISPOSABLE_DOMAINS_PATH=

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Logging
LOG_LEVEL=debug

# Socket.io
SOCKET_CORS_ORIGINS=https://crm.quoreb2b.com,https://app.intentmatics.com,http://localhost:3000,http://localhost:3001
