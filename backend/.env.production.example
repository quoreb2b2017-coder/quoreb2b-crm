# =============================================================================
# QuoreB2B CRM - EC2 Production (copy to .env.production on server)
# NEVER commit .env.production to git
# =============================================================================

NODE_ENV=production
PORT=4000
API_PREFIX=api
API_VERSION=v1

APP_NAME=QuoreB2B CRM API
APP_URL=https://api.quoreb2b.com

# Comma-separated — add your exact Vercel URL after deploy (e.g. https://quoreb2b-crm.vercel.app)
CORS_ORIGINS=https://crm.quoreb2b.com,https://YOUR-PROJECT.vercel.app
SOCKET_CORS_ORIGINS=https://crm.quoreb2b.com,https://YOUR-PROJECT.vercel.app

# MongoDB Atlas — whitelist EC2 public IP in Atlas Network Access
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/quoreb2b_crm?retryWrites=true&w=majority
MONGODB_MAX_POOL_SIZE=30
MONGODB_SYNC_INDEXES=true

# Redis on same EC2 (host network in deploy-backend.sh — use 127.0.0.1)
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_DB=0
REDIS_CACHE_PREFIX=quoreb2b:cache
REDIS_CACHE_TTL_LIVE_SECONDS=15
REDIS_CACHE_TTL_SECONDS=60
REDIS_CACHE_TTL_MEDIUM_SECONDS=180
REDIS_CACHE_TTL_LONG_SECONDS=600

ELASTICSEARCH_ENABLED=false

# Generate NEW secrets for production (openssl rand -base64 48)
JWT_ACCESS_SECRET=CHANGE_ME_MIN_32_CHARS_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_MIN_32_CHARS_REFRESH_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BULLMQ_PREFIX=quoreb2b

THROTTLE_TTL=60
THROTTLE_LIMIT=100

SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

LOG_LEVEL=info

BULK_EMAIL_VERIFICATION_PROVIDER=internal
BULK_EMAIL_SKIP_SMTP_PROBE=false
BULK_EMAIL_FAST_MODE=false
BULK_EMAIL_STOP_ON_VALID=false
BULK_EMAIL_SMTP_FROM=verify@quoreb2b.com
BULK_EMAIL_SMTP_TIMEOUT_MS=12000
BULK_EMAIL_PROSPECT_CONCURRENCY=8
BULK_EMAIL_PATTERN_CONCURRENCY=6
BULK_EMAIL_QUEUE_CONCURRENCY=8
BULK_EMAIL_PROSPECT_CHUNK_SIZE=100
BULK_EMAIL_MAX_PATTERNS=12
BULK_EMAIL_SKIP_CATCH_ALL_PROBE=false
BULK_EMAIL_MX_ONLY_FALLBACK=false
BULK_EMAIL_STRICT_MAILBOX_REJECT=false
BULK_EMAIL_DOMAIN_CACHE_TTL_MS=3600000
BULK_EMAIL_DNS_NEGATIVE_CACHE_TTL_MS=300000
BULK_EMAIL_MAX_ROWS_PER_BATCH=100000
BULK_EMAIL_SYNC_MAX_ROWS=200
